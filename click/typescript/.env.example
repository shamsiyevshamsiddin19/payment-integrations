# =============================================================================
#  Click to'lov integratsiyasi — sozlamalar
# =============================================================================
#
#  Bu faylni nusxa ko'chiring va `.env` deb nomlang:
#
#      cp .env.example .env        # Linux / macOS
#      copy .env.example .env      # Windows
#
#  Qiymatlarni Click kabinetidan olasiz: https://merchant.click.uz
#
#  `.env` faylini git'ga QO'SHMANG — u .gitignore da turibdi.
#
#  Next.js `.env` ni o'zi o'qiydi. Oddiy Node loyihasida:
#      node --env-file=.env ...      yoki      import "dotenv/config"
# =============================================================================


# --- MAJBURIY ----------------------------------------------------------------

# Xizmat (servis) ID.
# Kabinet -> "Mening xizmatlarim" -> xizmatingiz.
# Click yuborgan so'rovdagi service_id shu bilan solishtiriladi.
CLICK_SERVICE_ID=12345

# Merchant ID — savdogar raqamingiz.
# Kabinet -> Profil. To'lov havolasida ketadi.
CLICK_MERCHANT_ID=54321

# SECRET KEY — maxfiy kalit.
# Kabinet -> xizmat sozlamalari.
#
# Har bir so'rovning imzosi (sign_string) shu kalit bilan tekshiriladi.
# Bu kalitni bilgan odam soxta "to'landi" so'rovini yubora oladi, shuning uchun:
#   - kodga yozmang,
#   - loglarga chiqarmang,
#   - git'ga qo'shmang.
#
# ⚠️ Next.js: nomiga HECH QACHON `NEXT_PUBLIC_` qo'shmang — u brauzerga
# chiqib ketadi va kalitingiz ochilib qoladi.
CLICK_SECRET_KEY=bu_yerga_kabinetdagi_secret_key_ni_qoying

# Merchant user ID — kabinetdagi foydalanuvchi raqamingiz.
# Kabinet -> Profil. To'lov havolasida ketadi.
CLICK_MERCHANT_USER_ID=67890


# --- IXTIYORIY ---------------------------------------------------------------

# To'lovdan keyin foydalanuvchi qaytariladigan sahifangiz.
#
# DIQQAT: bu sahifaga tushish "to'landi" degani EMAS — u foydalanuvchi
# brauzeridan keladi va uni qo'lda yozib qo'yish mumkin. Haqiqiy holatni
# bazangizdan o'qing (to'lovni faqat Click'ning complete so'rovi tasdiqlaydi).
CLICK_RETURN_URL=https://sizning-domen.uz/payment/result

# Click to'lov sahifasining manzili. Odatda o'zgartirilmaydi.
CLICK_PAY_BASE_URL=https://my.click.uz/services/pay
