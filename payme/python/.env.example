# =============================================================================
#  Payme to'lov integratsiyasi — sozlamalar namunasi
# =============================================================================
#
#  Bu faylni nusxa ko'chiring va `.env` deb nomlang:
#
#      cp .env.example .env        # Linux / macOS
#      copy .env.example .env      # Windows
#
#  Qiymatlarni Payme kabinetidan olib to'ldiring:
#      https://business.payme.uz  ->  kirish  ->  Kassalar  ->  sozlamalar
#
#  OGOHLANTIRISH: `.env` faylini HECH QACHON git'ga qo'shmang. U .gitignore da
#  turibdi. Agar PAYME_SECRET_KEY bir marta ommaga chiqsa, uni kabinetdan
#  darhol yangilang.
# =============================================================================


# --- MAJBURIY -----------------------------------------------------------------

# Kassa ID (merchant id) — kabinetdagi kassangizning identifikatori.
# To'lov havolasida ("m=...") ishlatiladi.
PAYME_MERCHANT_ID=5cd108976ce4a8423da6d5c9

# Maxfiy kalit — eng muhim qiymat.
# Payme har bir so'rovni shu kalit bilan HTTP Basic Auth orqali tasdiqlaydi
# (Click'dagi kabi sign_string emas). Bu kalitni bilgan odam soxta
# "to'landi" so'rovini yubora oladi, shuning uchun:
#   - kodga yozmang,
#   - loglarga chiqarmang,
#   - git'ga qo'shmang.
PAYME_SECRET_KEY=bu_yerga_kabinetdagi_kalitni_qoying


# --- IXTIYORIY ----------------------------------------------------------------

# Payme Basic Auth'da yuboradigan login. Deyarli hamma vaqt "Paycom" —
# kabinetda boshqacha ko'rsatilmagan bo'lsa o'zgartirmang.
PAYME_MERCHANT_LOGIN=Paycom

# To'lov sahifasining manzili. Odatda o'zgartirilmaydi.
PAYME_CHECKOUT_BASE_URL=https://checkout.paycom.uz

# SQLite bazasi fayli (tayyor demo tranzaksiya kundaligi uchun).
# O'z bazangizni ulasangiz bu kerak emas.
PAYME_DB_PATH=payme_demo.db
