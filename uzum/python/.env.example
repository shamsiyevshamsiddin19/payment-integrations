# =============================================================================
#  Uzum Bank to'lov integratsiyasi — sozlamalar
# =============================================================================
#
#  Bu faylni nusxa ko'chiring va `.env` deb nomlang:
#
#      cp .env.example .env
#
#  Qiymatlarni Uzum Bank kabinetidan olasiz: https://merchants.uzumbank.uz
#
#  `.env` faylini HECH QACHON git'ga qo'shmang.
# =============================================================================


# --- MAJBURIY ----------------------------------------------------------------

# Xizmat (servis) ID — kabinetda xizmatingizga beriladi.
# Foydalanuvchilar Uzum Bank ilovasida xizmatingizni AYNAN shu ID orqali
# topadi (Click/Payme'dagidek to'lov havolasi bu yerda yo'q).
UZUM_SERVICE_ID=101202

# Webhook so'rovlarini tasdiqlash uchun LOGIN.
# Payme'dan farqli — bu doim "Paycom" emas, o'zingiz kabinetda belgilaysiz.
UZUM_WEBHOOK_LOGIN=bu_yerga_login_ni_qoying

# Webhook so'rovlarini tasdiqlash uchun PAROL.
# Har bir /check, /create, /confirm, /reverse, /status so'rovi shu bilan
# tekshiriladi (HTTP Basic Auth). Kodga yozmang, git'ga qo'shmang.
UZUM_WEBHOOK_SECRET=bu_yerga_parolni_qoying


# --- IXTIYORIY ---------------------------------------------------------------

# Namuna SQLite bazasi fayli — FAQAT uzum_orders.py dagi demo uchun.
# O'z bazangizni ulaganingizda kerak emas.
UZUM_DB_PATH=uzum_demo.db
